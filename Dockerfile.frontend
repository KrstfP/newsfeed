# Stage 1: Build
FROM node:22-alpine AS build
WORKDIR /app
COPY front/package*.json ./
RUN npm ci
COPY front/ .
RUN npm run build

# Stage 2: Runtime
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY front/nginx.conf.template /etc/nginx/templates/default.conf.template
EXPOSE 80
